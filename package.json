{
  "name": "tsts-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace root for @tsonic/tsts (TypeScript-native TypeScript compiler)",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.18"
  },
  "scripts": {
    "build": "npm --workspace @tsonic/tsts run build",
    "clean": "rm -rf .temp .tests .tsonic packages/tsts/.tests packages/tsts/generated packages/tsts/generated-test",
    "package:check": "npm --workspace @tsonic/tsts run package:check",
    "porter:scan": "node packages/tsts/tools/porter/porter-cli.mjs scan",
    "porter:status": "node packages/tsts/tools/porter/porter-cli.mjs status",
    "porter:verify": "node packages/tsts/tools/porter/porter-cli.mjs verify",
    "porter:reconcile-metadata": "node packages/tsts/tools/porter/porter-cli.mjs reconcile-metadata",
    "porter:scaffold": "node packages/tsts/tools/porter/porter-cli.mjs scaffold",
    "porter:scaffold-all": "node packages/tsts/tools/porter/porter-cli.mjs scaffold --all --write --append",
    "porter:facades": "node packages/tsts/tools/porter/porter-cli.mjs facades",
    "porter:large-files": "node packages/tsts/tools/porter/porter-cli.mjs large-files",
    "porter:ast": "node packages/tsts/tools/porter/porter-cli.mjs ast",
    "porter:diagnostics": "node packages/tsts/tools/porter/porter-cli.mjs diagnostics",
    "porter:skeleton-check": "node packages/tsts/tools/porter/porter-cli.mjs skeleton-check",
    "porter:sig-check": "node packages/tsts/tools/porter/porter-cli.mjs sig-check",
    "porter:test": "node --test packages/tsts/tools/porter/*.test.mjs",
    "source:test": "node packages/tsts/tools/source-tests/run.mjs",
    "tsgo-suite": "node packages/tsts/tools/tsgo-suite/run.mjs",
    "tsgo-suite:test": "node --test packages/tsts/tools/tsgo-suite/*.test.mjs",
    "corpus:setup": "node packages/tsts/tools/corpus/ast-parity.mjs setup",
    "corpus:ast": "node packages/tsts/tools/corpus/ast-parity.mjs ast",
    "corpus:list": "node packages/tsts/tools/corpus/ast-parity.mjs list",
    "profile:bench": "node packages/tsts/tools/profiling/bench.mjs",
    "profile:self": "node packages/tsts/tools/profiling/self-compile-bench.mjs",
    "profile:utf8": "node packages/tsts/tools/profiling/utf8-bench.mjs",
    "profile:scanner": "node packages/tsts/tools/profiling/scanner-bench.mjs",
    "profile:attribute": "node packages/tsts/tools/profiling/attribute.mjs",
    "bundled:generate": "node packages/tsts/tools/bundled/generate-bundled.mjs --write",
    "bundled:check": "node packages/tsts/tools/bundled/generate-bundled.mjs --check",
    "unicode:generate": "node packages/tsts/tools/unicode/generate-unicode-data.mjs --write",
    "unicode:check": "node packages/tsts/tools/unicode/generate-unicode-data.mjs --check",
    "status": "git status --short --branch"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@unicode/unicode-15.1.0": "^1.6.16",
    "typescript": "^6.0.3"
  }
}
