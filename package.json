{
  "name": "tsts-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace root for @tsonic/tsts (TypeScript-native TypeScript compiler)",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.18"
  },
  "scripts": {
    "build": "node ${TSONIC_CLI:-../tsonic/packages/cli/dist/index.js} build --project tsts",
    "test": "npm run test:node",
    "test:tsonic": "node ${TSONIC_CLI:-../tsonic/packages/cli/dist/index.js} test --project tsts",
    "generate": "node ${TSONIC_CLI:-../tsonic/packages/cli/dist/index.js} generate --project tsts",
    "restore": "node ${TSONIC_CLI:-../tsonic/packages/cli/dist/index.js} restore",
    "ast:generate": "cd packages/tsts && node --import ./tools/register.mjs tools/generateAst.ts",
    "api:encoder:generate": "cd packages/tsts && node --import ./tools/register.mjs tools/generateApiEncoder.ts",
    "diagnostics:generate": "cd packages/tsts && node --import ./tools/register.mjs tools/generateDiagnostics.ts",
    "ast:schema-check": "cd packages/tsts && node --import ./tools/register.mjs tools/checkSchema.ts",
    "ast:generated-check": "cd packages/tsts && node tools/checkGenerated.ts",
    "naming": "node packages/tsts/tools/checkNaming.ts",
    "completeness": "node packages/tsts/tools/checkCompleteness.ts",
    "completeness:json": "node packages/tsts/tools/checkCompleteness.ts --json",
    "parity": "node packages/tsts/tools/checkParity.ts",
    "parity:json": "node packages/tsts/tools/checkParity.ts --json",
    "logical-parity": "node packages/tsts/tools/checkLogicalParity.ts",
    "logical-parity:json": "node packages/tsts/tools/checkLogicalParity.ts --json",
    "logical-parity:report": "node packages/tsts/tools/checkLogicalParity.ts --no-fail",
    "tsgo:function-inventory": "node packages/tsts/tools/checkTsgoFunctionInventory.ts",
    "tsgo:control-skeleton": "node packages/tsts/tools/checkTsgoControlSkeleton.ts",
    "tsgo:corpus-impact": "node packages/tsts/tools/checkTsgoCorpusImpact.ts",
    "tsgo:work-packets": "node packages/tsts/tools/generateTsgoWorkPackets.ts",
    "typecheck": "node ../tsonic/node_modules/typescript/bin/tsc --noEmit -p packages/tsts/tsconfig.json --pretty false",
    "build:tsc": "node ../tsonic/node_modules/typescript/bin/tsc -p packages/tsts/tsconfig.json --outDir .temp/tsc-dist --pretty false && rm -rf .temp/tsc-dist/src/bundled/libs && cp -R packages/tsts/src/bundled/libs .temp/tsc-dist/src/bundled/libs",
    "test:node": "npm run build:tsc && node --test \".temp/tsc-dist/src/**/*.test.js\"",
    "test:tsgo": "npm run build:tsc && node --test \".temp/tsc-dist/src/runner/tsgoConformance.test.js\"",
    "test:tsgo:required": "npm run build:tsc && TSGO_REQUIRED=1 node --test \".temp/tsc-dist/src/runner/tsgoConformance.test.js\"",
    "verify": "npm run typecheck && npm run test:node && npm run ast:schema-check && npm run ast:generated-check && npm run naming && npm run parity"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@tsonic/core": "file:../core/versions/10",
    "@tsonic/dotnet": "file:../dotnet/versions/10",
    "@tsonic/js": "file:../js/versions/10",
    "@tsonic/nodejs": "file:../nodejs/versions/10"
  }
}
