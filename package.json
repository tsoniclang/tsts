{
  "name": "@tsonic/tsts",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript-native TypeScript compiler targeting TS-Go contracts",
  "type": "module",
  "bin": {
    "tsts": "./dist/src/cli/tsts.js"
  },
  "exports": {
    ".": "./dist/src/index.js"
  },
  "engines": {
    "node": ">=22.18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate": "tsx tools/generate-ast.ts",
    "schema:check": "tsx tools/check-schema.ts",
    "generated:check": "tsx tools/check-generated.ts",
    "test": "tsx --test test/**/*.test.ts",
    "completeness": "tsx tools/check-completeness.ts",
    "completeness:json": "tsx tools/check-completeness.ts --json",
    "verify": "npm run schema:check && npm run generate && npm run generated:check && npm run build && npm run test",
    "verify:full": "npm run verify && npm run completeness"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
