{
  "name": "tsts-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace root for @tsonic/tsts (TypeScript-native TypeScript compiler)",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.18"
  },
  "scripts": {
    "build": "npm --workspace @tsonic/tsts run build",
    "clean": "rm -rf .temp .tests .tsonic packages/tsts/.tests packages/tsts/generated packages/tsts/generated-test",
    "package:check": "npm --workspace @tsonic/tsts run package:check",
    "porter:scan": "node packages/tsts/tools/porter/porter.mjs scan",
    "porter:delta": "node packages/tsts/tools/porter/porter.mjs delta",
    "porter:delta-verify": "node packages/tsts/tools/porter/porter.mjs delta-verify",
    "porter:generated-source-coverage": "node packages/tsts/tools/porter/porter.mjs generated-source-coverage",
    "porter:status": "node packages/tsts/tools/porter/porter.mjs status",
    "porter:verify": "node packages/tsts/tools/porter/porter.mjs verify --strict-port",
    "porter:source-docs": "node packages/tsts/tools/porter/porter.mjs source-docs",
    "porter:scaffold": "node packages/tsts/tools/porter/porter.mjs scaffold",
    "porter:scaffold-all": "node packages/tsts/tools/porter/porter.mjs scaffold --all --write --append",
    "porter:facades": "node packages/tsts/tools/porter/porter.mjs facades",
    "porter:large-files": "node packages/tsts/tools/porter/porter.mjs large-files",
    "porter:ast": "node packages/tsts/tools/porter/porter.mjs ast",
    "porter:diagnostics": "node packages/tsts/tools/porter/porter.mjs diagnostics",
    "porter:skeleton-check": "node packages/tsts/tools/porter/porter.mjs skeleton-check",
    "porter:sig-check": "node packages/tsts/tools/porter/porter.mjs sig-check",
    "porter:test": "npm run porter:test:node && npm run porter:test:go",
    "porter:test:node": "node --test packages/tsts/tools/porter/*.test.mjs packages/tsts/tools/porter/test/*.test.mjs",
    "porter:test:go": "cd packages/tsts/tools/porter/go-extractor && go test ./...",
    "source:test": "node packages/tsts/tools/source-tests/run.mjs",
    "tsgo-suite": "node packages/tsts/tools/tsgo-suite/prepare-run.mjs",
    "tsgo-suite:verify-report": "node packages/tsts/tools/tsgo-suite/verify-report.mjs",
    "tsgo-suite:test": "node --test packages/tsts/tools/tsgo-suite/*.test.mjs",
    "tsgo-accepted:capture": "node packages/tsts/tools/tsgo-suite/capture-tsgo-accepted.mjs capture",
    "tsgo-accepted:verify": "node packages/tsts/tools/tsgo-suite/capture-tsgo-accepted.mjs verify",
    "corpus:setup": "node packages/tsts/tools/corpus/ast-parity.mjs setup",
    "corpus:ast": "node packages/tsts/tools/corpus/ast-parity.mjs ast",
    "corpus:list": "node packages/tsts/tools/corpus/ast-parity.mjs list",
    "corpus:verify": "node packages/tsts/tools/corpus/ast-parity.mjs verify",
    "corpus:test": "node --test packages/tsts/tools/corpus/*.test.mjs packages/tsts/tools/pinned-go-producer.test.mjs packages/tsts/tools/sealed-evidence.test.mjs packages/tsts/tools/tsgo-source-pin.test.mjs",
    "profile:bench": "node packages/tsts/tools/profiling/bench.mjs",
    "profile:gate": "node packages/tsts/tools/profiling/bench.mjs --gate",
    "profile:test": "node --test packages/tsts/tools/profiling/*.test.mjs",
    "profile:self": "node packages/tsts/tools/profiling/self-compile-bench.mjs",
    "profile:utf8": "node packages/tsts/tools/profiling/utf8-bench.mjs",
    "profile:scanner": "node packages/tsts/tools/profiling/scanner-bench.mjs",
    "profile:attribute": "node packages/tsts/tools/profiling/attribute.mjs",
    "bundled:generate": "node packages/tsts/tools/porter/porter.mjs bundled --write",
    "bundled:check": "node packages/tsts/tools/porter/porter.mjs bundled",
    "unicode:generate": "node packages/tsts/tools/porter/porter.mjs unicode --write",
    "unicode:check": "node packages/tsts/tools/porter/porter.mjs unicode",
    "status": "git status --short --branch"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@unicode/unicode-15.1.0": "^1.6.16",
    "typescript": "^6.0.3"
  }
}
