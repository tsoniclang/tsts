{
  "name": "tsts-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace root for @tsonic/tsts (TypeScript-native TypeScript compiler)",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.18"
  },
  "scripts": {
    "build": "node ../tsonic/packages/cli/dist/index.js build --project tsts",
    "test": "node ../tsonic/packages/cli/dist/index.js test --project tsts",
    "generate": "node ../tsonic/packages/cli/dist/index.js generate --project tsts",
    "ast:generate": "node packages/tsts/tools/generate-ast.ts",
    "ast:schema-check": "node packages/tsts/tools/check-schema.ts",
    "ast:generated-check": "node packages/tsts/tools/check-generated.ts",
    "completeness": "node packages/tsts/tools/check-completeness.ts",
    "completeness:json": "node packages/tsts/tools/check-completeness.ts --json"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@tsonic/core": "10.0.45",
    "@tsonic/dotnet": "^10.0.0",
    "@tsonic/globals": "^10.0.0",
    "@tsonic/js": "10.0.52",
    "@tsonic/nodejs": "10.0.53",
    "xunit-types": "*"
  }
}
