      "reason": "Node test mirrors for upstream TS-Go tests; these are validation artifacts, not production @tsgo-unit source."
    },
    {
      "match": "packages/tsts/src/cmd/tsgo/lsp.ts",
      "category": "forbidden-source",
      "reason": "The LSP command entrypoint must not exist in the active standalone compiler source tree."
    },
    {
      "match": "packages/tsts/src/cli/**",
      "category": "public-entrypoint",
      "reason": "Node executable adapter for the standalone compiler; it delegates to the TS-Go cmd/tsgo main port and has no upstream Go unit."
    },
    {
      "match": "packages/tsts/src/index.ts",
      "category": "public-entrypoint",
      "reason": "Package public API barrel for embedding the standalone compiler; it re-exports ported compiler surfaces and has no upstream Go unit."
    },
    {
      "match": "packages/tsts/src/services/**",
      "category": "public-api",
      "reason": "TypeScript-compatible public service APIs for embedding TSTS; additive host surface with no upstream Go unit."
    },
    {
      "match": "packages/tsts/src/extensions/**",
      "category": "public-api",
      "reason": "Additive compiler extension host public API; target-neutral infrastructure with no upstream Go unit."
    },
    {
      "match": "packages/tsts/src/internal/ast/generated/**",
      "category": "ast-generated",
      "reason": "Generated AST infrastructure emitted by porter:ast from packages/tsts/schema/tsgo/*; carries @tsgo-generated metadata, not @tsgo-unit."
    },
    {
      "match": "packages/tsts/src/internal/diagnostics/generated/**",
      "category": "diagnostics-generated",
      "reason": "Generated diagnostic message catalog emitted by porter:diagnostics from the pinned diagnostics_generated.go; carries @tsgo-generated metadata, not @tsgo-unit."
    },
    {
      "match": "packages/tsts/src/internal/stringutil/generated/**",
      "category": "unicode-generated",
      "reason": "Generated Unicode data tables (identifier ID_Start/ID_Continue ranges, Cased/Case_Ignorable ranges, special-casing map) emitted by porter:unicode from the pinned @unicode/unicode-15.1.0 package; carries @tsgo-generated metadata, not @tsgo-unit."
    },
    {
      "match": "packages/tsts/src/internal/bundled/*_generated.ts",
      "category": "bundled-generated",
      "reason": "Generated bundled library indexes emitted by bundled:generate from TS-Go internal/bundled/libs; carries @tsgo-generated metadata, not @tsgo-unit."
    },
    {
      "match": "packages/tsts/src/internal/bundled/libs/**",
      "category": "bundled-generated",
      "reason": "Generated bundled TypeScript lib declarations copied from TS-Go internal/bundled/libs; carries @tsgo-generated metadata, not @tsgo-unit."
    },
    {
      "match": "packages/tsts/src/internal/ast/*_generated.ts",
      "category": "ast-compat-reexport",
      "reason": "Thin re-export barrels (ast_generated.ts/kind_generated.ts) aliasing the canonical generated/* modules to the scaffolder's Go-file-derived import paths; pure re-exports, no @tsgo-unit."
    },
    {
      "match": "packages/tsts/src/go/*.ts",
      "category": "go-compat-layer",
      "reason": "The Go compatibility layer is authored TypeScript infrastructure, not a TS-Go source unit."
    },
    {
      "match": "packages/tsts/src/go/**",
      "category": "go-compat-layer",
      "reason": "The Go compatibility layer is authored TypeScript infrastructure, not a TS-Go source unit."
    },
    {
      "match": "packages/tsts/src/internal/fswatch/**",
      "category": "host-native",
      "reason": "Authored host-native facade for the upstream internal/fswatch package (out-of-scope OS file-watch internals: fanotify/FSEvents/kqueue/inotify). Exposes the public surface the execute watcher consumes with a stub that throws TSGO_EXTERNAL_FACADE_UNIMPLEMENTED; not a ported TS-Go unit, so it carries no @tsgo-unit metadata."
    },
    {
      "match": "packages/tsts/src/**/*.ts",
      "category": "requires-tsgo-unit",
      "reason": "Every source file must carry at least one @tsgo-unit unless an explicit policy allows it."
    }
  ],
  "overrides": [
