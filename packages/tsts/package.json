{
  "name": "@tsonic/tsts",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript-native TypeScript compiler targeting TS-Go contracts",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./index.js": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "tsts": "./dist/src/cli/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "package:check": "node tools/package/check-built-package.mjs",
    "prepack": "npm run build && npm run package:check"
  },
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.js.map",
    "dist/src/**/*.d.ts",
    "dist/src/**/*.d.ts.map"
  ]
}
